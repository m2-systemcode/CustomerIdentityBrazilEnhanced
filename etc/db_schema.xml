<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="quote">
        <column xsi:type="varchar" name="cpf" nullable="true" length="32" comment="CPF"/>
        <column xsi:type="varchar" name="cnpj" nullable="true" length="32" comment="CNPJ"/>
        <column xsi:type="varchar" name="socialname" nullable="true" length="255" comment="Social Name"/>
        <column xsi:type="varchar" name="tradename" nullable="true" length="255" comment="Trade Name"/>
    </table>
    <table name="sales_order">
        <column xsi:type="varchar" name="cpf" nullable="true" length="32" comment="CPF"/>
        <column xsi:type="varchar" name="cnpj" nullable="true" length="32" comment="CNPJ"/>
        <column xsi:type="varchar" name="socialname" nullable="true" length="255" comment="Social Name"/>
        <column xsi:type="varchar" name="tradename" nullable="true" length="255" comment="Trade Name"/>
    </table>
</schema>
